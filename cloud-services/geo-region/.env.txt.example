#/-------------------[DOTENV_PUBLIC_KEY]--------------------/
#/            public-key encryption for .env files          /
#/       [how it works](https://dotenvx.com/encryption)     /
#/----------------------------------------------------------/
DOTENV_PUBLIC_KEY=""

# Must match EXPO_PUBLIC_GEO_REGION_API_KEY in EAS / .env.local
# Format: lq_geo_v1_<alphanumeric> (must not be left as encrypted:...)
GEO_REGION_PUBLIC_API_KEY=

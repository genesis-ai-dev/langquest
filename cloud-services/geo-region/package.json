{
	"name": "geo-region",
	"version": "1.0.0",
	"private": true,
	"description": "Ephemeral IP-to-country lookup for EU/EEA/UK analytics gating. No storage, no logging.",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev --var $(dotenvx keypair -f .env.txt --format=colon)",
		"deploy": "wrangler deploy",
		"encrypt": "dotenvx encrypt -f .env.txt",
		"cf-typegen": "wrangler types",
		"typecheck": "wrangler types --check && tsc --noEmit"
	},
	"dependencies": {
		"@dotenvx/dotenvx": "^1.66.0"
	},
	"devDependencies": {
		"typescript": "^5.5.2",
		"wrangler": "^4.93.0"
	}
}
